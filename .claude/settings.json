{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": ".claude/hooks/session-context.sh"
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": ".claude/hooks/secret-scan.sh",
        "toolNames": ["Bash", "Write", "Edit"]
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": ".claude/hooks/check-doc-sync.sh",
        "toolNames": ["Write", "Edit"]
      }
    ],
    "Notification": [
      {
        "type": "command",
        "command": ".claude/hooks/notify.sh"
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(rm -r -f /)",
      "Bash(rm -r -f ~)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(bash <(curl*)",
      "Bash(bash <(wget*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(find / -delete*)",
      "Bash(mkfs*)",
      "Bash(dd if=* of=/dev/*)"
    ]
  }
}
